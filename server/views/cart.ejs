<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Giỏ hàng</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: Arial, sans-serif;
            background: #f5f5f5;
        }

        .header {
            background: #333;
            color: white;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header h1 {
            font-size: 24px;
        }

        .header nav a {
            color: white;
            text-decoration: none;
            margin-left: 20px;
        }

        .header nav a:hover {
            text-decoration: underline;
        }

        .cart-badge {
            background: #e74c3c;
            color: white;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 12px;
        }

        .container {
            max-width: 1000px;
            margin: 20px auto;
            padding: 0 20px;
        }

        h2 {
            margin-bottom: 20px;
            color: #333;
        }

        .cart-empty {
            background: white;
            padding: 40px;
            text-align: center;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }

        .cart-table {
            width: 100%;
            background: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }

        .cart-table th,
        .cart-table td {
            padding: 15px;
            text-align: left;
            border-bottom: 1px solid #eee;
        }

        .cart-table th {
            background: #f8f9fa;
            font-weight: bold;
        }

        .cart-table img {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 4px;
        }

        .cart-table .product-name {
            font-weight: bold;
        }

        .cart-table .price {
            color: #e74c3c;
        }

        .quantity-input {
            width: 60px;
            padding: 5px;
            text-align: center;
            border: 1px solid #ddd;
            border-radius: 4px;
        }

        .btn {
            padding: 8px 15px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            text-decoration: none;
            font-size: 14px;
        }

        .btn-danger {
            background: #e74c3c;
            color: white;
        }

        .btn-primary {
            background: #3498db;
            color: white;
        }

        .btn-success {
            background: #27ae60;
            color: white;
        }

        .btn:hover {
            opacity: 0.9;
        }

        .cart-total {
            background: white;
            padding: 20px;
            margin-top: 20px;
            border-radius: 8px;
            text-align: right;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }

        .cart-total h3 {
            color: #e74c3c;
            font-size: 24px;
            margin-bottom: 15px;
        }

        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            color: #3498db;
            text-decoration: none;
        }

        .back-link:hover {
            text-decoration: underline;
        }
    </style>
</head>

<body>
    <header class="header">
        <h1>🛒 Shop Online</h1>
        <nav>
            <a href="/shop">Sản phẩm</a>
            <a href="/shop/cart">Giỏ hàng <span class="cart-badge">
                    <%= cartCount %>
                </span></a>
        </nav>
    </header>

    <div class="container">
        <a href="/shop" class="back-link">← Tiếp tục mua sắm</a>
        <h2>🛒 Giỏ hàng của bạn</h2>

        <% if (cart.length===0) { %>
            <div class="cart-empty">
                <h3>Giỏ hàng trống</h3>
                <p style="margin: 20px 0;">Bạn chưa có sản phẩm nào trong giỏ hàng.</p>
                <a href="/shop" class="btn btn-primary">Mua sắm ngay</a>
            </div>
            <% } else { %>
                <table class="cart-table">
                    <thead>
                        <tr>
                            <th>Hình ảnh</th>
                            <th>Sản phẩm</th>
                            <th>Giá</th>
                            <th>Số lượng</th>
                            <th>Thành tiền</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% cart.forEach(function(item) { %>
                            <tr>
                                <td>
                                    <% if (item.images && item.images[0]) { %>
                                        <img src="data:image/jpg;base64,<%= item.images[0] %>" alt="<%= item.name %>">
                                        <% } else { %>
                                            <img src="https://via.placeholder.com/80x80?text=No+Image" alt="No Image">
                                            <% } %>
                                </td>
                                <td class="product-name">
                                    <%= item.name %>
                                </td>
                                <td class="price">
                                    <%= item.price?.toLocaleString() %> VNĐ
                                </td>
                                <td>
                                    <form action="/shop/cart/update" method="POST" style="display:flex; gap:5px;">
                                        <input type="hidden" name="productId" value="<%= item._id %>">
                                        <input type="number" name="quantity" value="<%= item.quantity %>" min="1"
                                            max="99" class="quantity-input">
                                        <button type="submit" class="btn btn-primary">Cập nhật</button>
                                    </form>
                                </td>
                                <td class="price">
                                    <%= (item.price * item.quantity).toLocaleString() %> VNĐ
                                </td>
                                <td>
                                    <form action="/shop/cart/remove/<%= item._id %>" method="POST"
                                        style="display:inline;">
                                        <button type="submit" class="btn btn-danger">Xóa</button>
                                    </form>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                </table>

                <div class="cart-total">
                    <h3>Tổng cộng: <%= total.toLocaleString() %> VNĐ</h3>
                    <button class="btn btn-success" style="font-size: 18px; padding: 12px 30px;">Thanh toán</button>
                </div>
                <% } %>
    </div>
</body>

</html>